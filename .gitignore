# ──────────────────────────────────────────────
# Third-party Asset Store packages (re-import from Asset Store / Package Manager)
# ──────────────────────────────────────────────

# Interior Asset — furniture, walls, props for interior scenes (~743 MB)
Assets/Interior Asset/
Assets/Interior Asset.meta

# Sci-Fi Office Lite — sci-fi themed office environment (~274 MB)
Assets/ScifiOfficeLite/
Assets/ScifiOfficeLite.meta

# Barking Dog — 3D Free Modular Kit, modular building pieces (~52 MB)
Assets/_Barking_Dog/
Assets/_Barking_Dog.meta

# Studio Billion — House Interior environment pack (~4 MB)
Assets/StudioBillion/
Assets/StudioBillion.meta

# ──────────────────────────────────────────────
# Unity / XR SDK auto-generated assets (recreated by packages on import)
# ──────────────────────────────────────────────

# Meta XR SDK project-level settings
Assets/MetaXR/
Assets/MetaXR.meta

# Oculus SDK project config
Assets/Oculus/
Assets/Oculus.meta

# Android plugins generated by Oculus/Meta SDK
Assets/Plugins/
Assets/Plugins.meta

# ──────────────────────────────────────────────
# Unity template / sample assets (included by default in new projects)
# ──────────────────────────────────────────────

# Unity sample assets shipped with project templates (~16 MB)
Assets/Samples/
Assets/Samples.meta

# TextMesh Pro essentials — auto-imported by Unity on first use (~7 MB)
Assets/TextMesh Pro/
Assets/TextMesh Pro.meta

# Mobile AR Template starter assets (~5 MB)
Assets/MobileARTemplateAssets/
Assets/MobileARTemplateAssets.meta

# Scene Template default assets (~1.5 MB)
Assets/SceneTemplateAssets/
Assets/SceneTemplateAssets.meta

# Universal Asset Library — auto-generated URP asset index
Assets/UniversalAssetLibrary.asset
Assets/UniversalAssetLibrary.asset.meta

# ──────────────────────────────────────────────
# Keep these folders in git (important for Unity to restore packages/settings)
# ──────────────────────────────────────────────
!Packages/
!ProjectSettings/
!Assets/
